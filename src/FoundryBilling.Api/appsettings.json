{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Azure": {
    "ManagementBaseUrl": "https://management.azure.com/"
  },
  "Sync": {
    "IntervalMinutes": 60,
    "MetricLookbackHours": 2
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "AllowedHosts": "*"
}
